# Dev: by default Vite proxies /api → http://localhost:5000
# If your local server runs on another port, set:
# VITE_PROXY_TARGET=http://localhost:5001
# If you want to use the deployed server in dev, set:
# VITE_PROXY_TARGET=https://drserver.vercel.app
#
# Production: full API URL (optional override)
# VITE_API_URL=https://drserver.vercel.app/api
